# Cloudflare Pages custom headers

# Immutable assets (content-hashed filenames)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# JS bundles: Metro uses source-hash (not content-hash) for filenames,
# so the same filename may have different content across builds.
# Must revalidate on every request to avoid cross-build module mismatch.
/assets/js/*
  Cache-Control: no-cache

/assets/audio/*
  Cache-Control: public, max-age=31536000, immutable

/assets/audio_end/*
  Cache-Control: public, max-age=31536000, immutable

/assets/pwa/*
  Cache-Control: public, max-age=31536000, immutable

# HTML must revalidate on every request
# (stale HTML references deleted JS bundles → white screen)
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Service Worker must revalidate on every request
/sw.js
  Cache-Control: no-cache

# WeChat domain verification file
/HVChYlYloJ.txt
  Content-Type: text/plain
  Cache-Control: no-cache, no-store, must-revalidate

# Security headers for all responses
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
