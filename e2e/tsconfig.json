{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@werewolf/game-engine": ["../packages/game-engine/src/index.ts"],
      "@werewolf/game-engine/*": ["../packages/game-engine/src/*"]
    }
  },
  "include": ["**/*.ts"]
}
