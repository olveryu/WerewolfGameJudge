# ============================================
# 生产环境默认值（已提交到 git）
# ============================================
#
# EXPO_PUBLIC_* 不是 secret — 会 inline 到 JS bundle，客户端可见。
#
# 本地开发覆盖：
#   .env.local（gitignored）设置 EXPO_PUBLIC_CF_API_URL 等
#   Expo 加载优先级：.env.local > .env
#
# ============================================

EXPO_PUBLIC_SENTRY_DSN=https://d20e76c8c3cd8034dbb9b32f8576db10@o4510871644209152.ingest.us.sentry.io/4510871719378944

# ============================================
# Metro 构建优化（非 EXPO_PUBLIC_*，仅构建时生效）
# ============================================

# 启用 Metro tree shaking — 移除未使用的 ESM 导出（production only）
EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1
EXPO_UNSTABLE_TREE_SHAKING=1
