{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["App.tsx", "scripts/*.{ts,mjs,sh}", "functions/**/*.ts", "e2e/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts", "__mocks__/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "react-dom",
        "@expo/vector-icons",
        "expo-updates",
        "expo-system-ui",
        "expo-asset",
        "html2canvas",
        "jsdom"
      ]
    },
    "packages/game-engine": {
      "project": ["src/**/*.ts"]
    }
  }
}
