{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["miniprogram-ci"],
  "workspaces": {
    ".": {
      "entry": ["App.tsx!", "scripts/*.{ts,mjs,sh}", "functions/**/*.ts!", "e2e/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}!", "e2e/**/*.ts", "__mocks__/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@expo/vector-icons",
        "expo-updates",
        "expo-system-ui",
        "expo-asset",
        "html2canvas",
        "jest-environment-jsdom",
        "@cloudflare/vitest-pool-workers",
        "vitest"
      ]
    },
    "packages/game-engine": {
      "project": ["src/**/*.ts!"]
    },
    "packages/api-worker": {
      "project": ["src/**/*.ts!"],
      "ignoreDependencies": ["cloudflare"]
    }
  }
}
