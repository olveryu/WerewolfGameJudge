{
  "name": "werewolfgamejudge",
  "version": "1.13.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --no-coverage --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:all": "pnpm -r --include-workspace-root run test",
    "test:watch": "jest --watch",
    "e2e": "playwright test --reporter=list",
    "e2e:core": "pnpm exec playwright test --workers=1 --reporter=line --trace=on --max-failures=1",
    "e2e:remote": "E2E_ENV=remote pnpm exec playwright test --workers=1 --reporter=line --trace=on --max-failures=1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "fix": "pnpm run lint:fix && pnpm run format:write",
    "quality": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test:all",
    "e2e:night": "playwright test --reporter=list night-2p night-6p restart",
    "e2e:ui": "playwright test --ui",
    "dev": "concurrently -n worker,web -c blue,green \"pnpm --filter @werewolf/api-worker run dev\" \"EXPO_PUBLIC_BACKEND=cloudflare EXPO_PUBLIC_CF_API_URL=http://localhost:8787 expo start --web\"",
    "deploy": "bash scripts/deploy.sh",
    "release": "bash scripts/release.sh",
    "badges:generate": "node scripts/generate-badges.mjs",
    "badges:validate": "node scripts/generate-badges.mjs --validate-only",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20.20.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/dom-webview": "~55.0.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "@werewolf/game-engine": "workspace:*",
    "expo": "55.0.12",
    "expo-audio": "~55.0.12",
    "expo-blur": "^55.0.13",
    "expo-file-system": "^55.0.15",
    "expo-haptics": "^55.0.13",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.17",
    "expo-linear-gradient": "~55.0.12",
    "expo-sharing": "^55.0.17",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-logs": "^5.6.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "sonner-native": "^0.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-expo": "^55.0.14",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
