{
  "name": "@werewolf/game-engine",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./engine/*": {
      "types": "./src/engine/*.ts",
      "default": "./dist/engine/*.js"
    },
    "./werewolf/*": {
      "types": "./src/werewolf/*.ts",
      "default": "./dist/werewolf/*.js"
    },
    "./werewolf/store": {
      "types": "./src/werewolf/store/index.ts",
      "default": "./dist/werewolf/store/index.js"
    },
    "./werewolf/store/*": {
      "types": "./src/werewolf/store/*.ts",
      "default": "./dist/werewolf/store/*.js"
    },
    "./werewolf/protocol/*": {
      "types": "./src/werewolf/protocol/*.ts",
      "default": "./dist/werewolf/protocol/*.js"
    },
    "./werewolf/models/*": {
      "types": "./src/werewolf/models/*.ts",
      "default": "./dist/werewolf/models/*.js"
    },
    "./werewolf/models/roles": {
      "types": "./src/werewolf/models/roles/index.ts",
      "default": "./dist/werewolf/models/roles/index.js"
    },
    "./werewolf/models/roles/*": {
      "types": "./src/werewolf/models/roles/*.ts",
      "default": "./dist/werewolf/models/roles/*.js"
    },
    "./werewolf/models/actions/*": {
      "types": "./src/werewolf/models/actions/*.ts",
      "default": "./dist/werewolf/models/actions/*.js"
    },
    "./werewolf/resolvers/*": {
      "types": "./src/werewolf/resolvers/*.ts",
      "default": "./dist/werewolf/resolvers/*.js"
    },
    "./fibking/*": {
      "types": "./src/fibking/*.ts",
      "default": "./dist/fibking/*.js"
    },
    "./engine/store": {
      "types": "./src/engine/store/index.ts",
      "default": "./dist/engine/store/index.js"
    },
    "./engine/store/*": {
      "types": "./src/engine/store/*.ts",
      "default": "./dist/engine/store/*.js"
    },
    "./protocol/*": {
      "types": "./src/protocol/*.ts",
      "default": "./dist/protocol/*.js"
    },
    "./cosmetics/*": {
      "types": "./src/cosmetics/*.ts",
      "default": "./dist/cosmetics/*.js"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./dist/utils/*.js"
    },
    "./growth": {
      "types": "./src/growth/index.ts",
      "default": "./dist/growth/index.js"
    },
    "./growth/*": {
      "types": "./src/growth/*.ts",
      "default": "./dist/growth/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --no-coverage --forceExit"
  },
  "devDependencies": {}
}
