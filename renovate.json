{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "timezone": "Asia/Shanghai",
  "rangeStrategy": "bump",
  "prConcurrentLimit": 5,
  "postUpdateOptions": ["pnpmDedupe"],
  "postUpgradeTasks": {
    "commands": ["pnpm exec prettier --write {{{fileResultsArray}}}"],
    "fileFilters": ["**/*.json", "**/*.js", "**/*.ts", "**/*.md"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch/minor devDependencies",
      "matchUpdateTypes": ["patch", "minor"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "description": "Group Expo SDK packages",
      "groupName": "expo",
      "groupSlug": "expo",
      "matchPackageNames": ["/^expo/", "/^@expo//"]
    },
    {
      "description": "Group React Native packages",
      "groupName": "react-native",
      "groupSlug": "react-native",
      "matchPackageNames": ["/^react-native/", "/^@react-native/"]
    },
    {
      "description": "Group ESLint packages",
      "groupName": "eslint",
      "groupSlug": "eslint",
      "matchPackageNames": ["/eslint/"]
    },
    {
      "description": "Group testing packages",
      "groupName": "testing",
      "groupSlug": "testing",
      "matchPackageNames": ["/jest/", "/@testing-library/", "/@playwright/"]
    },
    {
      "description": "Group Sentry packages",
      "groupName": "sentry",
      "groupSlug": "sentry",
      "matchPackageNames": ["/@sentry//"]
    },
    {
      "description": "Group dev tooling (prettier, husky, lint-staged, typescript)",
      "matchPackageNames": ["prettier", "husky", "lint-staged", "typescript", "globals", "glob"],
      "groupName": "dev-tooling",
      "groupSlug": "dev-tooling"
    }
  ]
}
